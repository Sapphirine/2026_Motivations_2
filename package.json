{
  "name": "motiveops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:worker": "wrangler dev src/worker.ts",
    "dev:all": "sh -c 'trap \"trap - INT TERM EXIT; kill 0\" INT TERM EXIT; npm run dev:worker & npm run dev & wait'",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsc --noEmit",
    "eval:local": "esbuild scripts/run-local-evaluation.ts --bundle --platform=node --format=esm --outfile=.wrangler/tmp/run-local-evaluation.mjs && node .wrangler/tmp/run-local-evaluation.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "hono": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
