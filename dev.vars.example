APP_ENV=local
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LLM_PROVIDER_DEFAULT=openai
OPENAI_MODEL=gpt-5.4-nano
OPENAI_MODEL_ALLOWLIST=gpt-5.4-nano
RUN_TIMEOUT_SECONDS=25
RUN_RATE_LIMIT=12
RUN_RATE_LIMIT_WINDOW_SECONDS=3600
ARTIFACT_MAX_BYTES=500000
ARTIFACT_RETENTION_DAYS=14
DEMO_MODE=true

# Secret, set with `npx wrangler secret put OPENAI_API_KEY` or local secret handling.
# OPENAI_API_KEY=
